# =============================================================
# 皖美信用平台 · .gitignore
# =============================================================

# ----- 密钥与配置（绝不提交） -----
.env
.env.local
.env.production
backend/.env
*.pem
*.key
*.pfx
*.p12
credentials*.json
secret*.json
id_rsa
id_rsa.pub

# ----- AI 工具与编辑器内部数据 -----
.claude/
.codebuddy/
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# ----- 原始参考材料与第三方参考项目（不重新分发） -----
materials/
lumina-login/

# ----- 中间输出 / 设计文档草稿 / 测试截图（可选排除；若要公开演示可保留） -----
# output/   # ← 若希望公开设计迭代文档可注释此行
output/**/screenshots/
output/**/__pycache__/

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ----- Node -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ----- 日志与临时文件 -----
backend/logs/
logs/
*.log
tmp/
temp/
.tmp/

# ----- 操作系统 -----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- 打包产物 -----
dist/
build/
out/
*.zip
*.tar.gz
*.7z

# ----- Playwright 测试产物 -----
playwright-report/
test-results/
.playwright/

# ----- Backend runtime -----
backend/logs/*.log
