# =============================================================
# 皖美信用平台 · 后端配置（.env 模板）
# -------------------------------------------------------------
# 使用方法：
#   1) 复制本文件为同目录下的 .env（绝不提交到 Git）
#   2) 将 QWEN36_MAX_API_KEY 的值替换为您的真实 API Key
#   3) 其他参数按需调整
#   4) 启动：python backend/app.py
#
# 安全要求：
#   - .env 文件必须加入 .gitignore
#   - Linux 下 chmod 600 .env，仅所有者可读
#   - 生产环境请使用 Vault/KMS 等密钥管理系统
#   - API Key 严禁硬编码、严禁前端暴露、严禁提交代码仓库
#   - 密钥轮换周期建议 ≤ 90 天
# =============================================================

# ===== 大模型 API 配置（必填） =====
QWEN36_MAX_API_KEY=sk-YOUR_ACTUAL_API_KEY_HERE
QWEN36_MAX_MODEL=qwen3-max-preview
QWEN36_MAX_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 接口参数 =====
QWEN_TIMEOUT_SECONDS=90
QWEN_MAX_RETRIES=2
QWEN_MAX_CONCURRENCY=20
QWEN_STREAM_ENABLED=true
QWEN_TEMPERATURE=0.6
QWEN_MAX_TOKENS=4096

# ===== 思考链模式（qwen3 系列支持） =====
QWEN_ENABLE_THINKING=true
QWEN_THINKING_BUDGET=2048

# ===== 服务配置 =====
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8766
BACKEND_DEBUG=false
CORS_ALLOW_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# ===== 审计与日志 =====
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=./logs/audit.log
APP_LOG_PATH=./logs/app.log
LOG_LEVEL=INFO

# ===== 安全配置 =====
# 调用速率限制：每分钟每IP最大调用次数
RATE_LIMIT_PER_MIN=60
# 最大输入长度（字符）
MAX_INPUT_LENGTH=8000
# 敏感词过滤开关
CONTENT_FILTER_ENABLED=true

# ===== 降级策略 =====
# 无 API Key 时使用 Mock 响应（开发/演示用）
ENABLE_MOCK_FALLBACK=true
